generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ClientCompany {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  contactName  String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  mealRequests MealRequest[]

  @@index([active])
  @@map("client_companies")
}

model MealRequest {
  id           String        @id @default(cuid())
  requestNo    String        @unique
  companyId    String
  serviceDate  DateTime
  headcount    Int
  status       String        @default("submitted")
  note         String?
  eatenAt      DateTime?
  collectedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      ClientCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, serviceDate])
  @@index([serviceDate])
  @@index([status])
  @@map("meal_requests")
}

model MealRequestCounter {
  key       String @id
  nextValue Int

  @@map("meal_request_counters")
}
